{
  "publisher": "ntufar",
  "name": "c2st",
  "displayName": "C2ST - C to Structured Text",
  "description": "AI-powered C to IEC 61131-3 Structured Text converter using Mistral",
  "version": "0.0.10",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ntufar/c2st"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "C",
    "IEC 61131-3",
    "Structured Text",
    "PLC",
    "Mistral",
    "AI"
  ],
  "activationEvents": [
    "onCommand:c2st.convertSelection",
    "onCommand:c2st.configureProvider",
    "onCommand:c2st.showLogs",
    "onLanguage:c"
  ],
  "extensionPack": [
    "serhioromano.vscode-st"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "c2st.convertSelection",
        "title": "C2ST: Convert C to ST"
      },
      {
        "command": "c2st.configureProvider",
        "title": "C2ST: Configure AI Provider and API Key"
      },
      {
        "command": "c2st.showLogs",
        "title": "C2ST: Show Logs"
      }
    ],
    "keybindings": [
      {
        "command": "c2st.convertSelection",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "C2ST",
      "properties": {
        "c2st.aiProvider": {
          "type": "string",
          "default": "mistral",
          "enum": [
            "mistral",
            "openai",
            "anthropic",
            "google"
          ],
          "enumDescriptions": [
            "Mistral AI",
            "OpenAI",
            "Anthropic",
            "Google AI (Gemini)"
          ],
          "description": "Select the AI provider to use for conversion",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile-tests": "tsc -p tsconfig.json --outDir out",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "tsc --noEmit",
    "vscode:prepublish": "npm run compile -- --minify",
    "package": "vsce package",
    "pretest": "npm run compile-tests",
    "test": "node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "mocha": "^11.3.0",
    "sinon": "^21.1.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
